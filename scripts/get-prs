#
# Parse a PR description body for comments of the form
#   "[T|t]est with[:]? <ref> ((, | and) <ref>)*"
# where
#   <ref>     = <pr-ref> | <git-ref>
#   <pr-ref>  = "<org>/<repo>#<id>"
#             | "https://github.com/<org>/<repo>/pull/<id>"
#   <git-ref> = "<org>/<repo>@<branch-or-sha>"
#             | "https://github.com/<org>/<repo>/tree/<branch>"
#             | "https://github.com/<org>/<repo>/commit/<sha>"
#
# For URLs in comments, the Github GUI displays them in their short form (e.g.
# "<org>/<repo>#<id>"), even if the full URL is what the parser finds.
# For convenience, we support both forms.
#
# Expects a GitHub event file to be available for the PR number.
#
# Outputs space separated list of:
#   "<org>/<repo>#<id>"     for pull requests
#   "<org>/<repo>@<ref>"    for branches or commit SHAs
# Outputs empty string if no such references.
#
# Commit SHAs must be the full 40-char hash (short SHAs do not work with git fetch)

import json
import os
import re
import sys

from github import Github

# Using "(?:...)" makes a regex a non-capturing group, which is an atomic
# expression that operators can be applied to safely.
def regex_atom(regex):
    return f"(?:{regex})"

test_start_re = regex_atom("[Tt]est with:?")
org_re        = regex_atom("[a-zA-Z0-9_-]+")
repo_re       = regex_atom("[a-zA-Z0-9_-]+")
pr_id_re      = regex_atom("[0-9]+")
# Branch+commit-sha; branch names can contain /
branch_re     = regex_atom("[a-zA-Z0-9_][a-zA-Z0-9_./-]*")

# Matching ref_re always produces 7 results and only exactly one of the four
# alternatives below produces non-empty groups.
# t[0/1/3/5] being non-empty indicates which one.
#   t[0]              pr_ref_short_re   ("<org>/<repo>#<id>")
#   t[1], t[2]        pr_ref_url_re     ("<org>/<repo>", "<id>")
#   t[3], t[4]        git_ref_short_re  ("<org>/<repo>", "<branch-or-sha>")
#   t[5], t[6]        git_ref_url_re    ("<org>/<repo>", "<branch-or-sha>")
pr_ref_short_re  = regex_atom(f"({org_re}/{repo_re}#{pr_id_re})")
pr_ref_url_re    = regex_atom(f"https://github.com/({org_re}/{repo_re})/pull/({pr_id_re})")
git_ref_short_re = regex_atom(f"({org_re}/{repo_re})@({branch_re})")
git_ref_url_re   = regex_atom(f"https://github.com/({org_re}/{repo_re})/(?:tree|commit)/({branch_re})")
ref_re           = regex_atom(f"{pr_ref_short_re}|{pr_ref_url_re}|{git_ref_short_re}|{git_ref_url_re}")

# For the reference list, multiple commas or spaces work ("<ref>,  ,, <ref>"),
# it's practically support of empty items. The Oxford comma ("<ref>, and <ref>")
# is also supported.
ref_sep_re            = regex_atom("[, ]+(?:and)?[ ]*")
ref_list_next_item_re = regex_atom(f"{ref_sep_re}{ref_re}")
ref_list_re           = regex_atom(f"{ref_re}{ref_list_next_item_re}*")

# Finally, the complete regex can be built. In Python the number of groups that
# match an expression is fixed. For repeating matches like in the list, only the
# last match is returned for each group. To work around this, a matching group
# for the whole reference list is used and then decomposed in a second step.
test_with_refs_cre = re.compile(f"{test_start_re}[ ]+({ref_list_re})")
ref_cre            = re.compile(ref_re)

def find_refs_to_test_with(text):
    refs = []
    if text is not None:
        for line in text.splitlines():
            m = test_with_refs_cre.match(line)
            if m:
                for t in ref_cre.findall(m.group(0)):
                    if t[0]:
                        refs.append(t[0])                # pr_ref_short
                    elif t[1]:
                        refs.append(f"{t[1]}#{t[2]}")    # pr_ref_url
                    elif t[3]:
                        refs.append(f"{t[3]}@{t[4]}")    # git_ref_short
                    else:
                        refs.append(f"{t[5]}@{t[6]}")    # git_ref_url
    return refs

def unit_test():
    a = find_refs_to_test_with(
        "This is a test\n" \
        "-- Good case tests for basic things:\n" \
        "Test with: org101/repo101#101\n" \
        "test with https://github.com/org102/repo102/pull/102\n" \
        "Test with: \n" \
        "-- Good case tests for lists:\n" \
        "Test with: org103/repo103#103 and org104/repo104#104," \
            "https://github.com/org105/repo105/pull/105, and org106/repo106#106\n" \
        "-- Trailing list separators are accepted:\n" \
        "Test with: https://github.com/org107/repo107/pull/107,\n" \
        "Test with: org108/repo108#108 and \n" \
        "-- Space separators are accepted:\n" \
        "Test with: org109/repo109#109 org110/repo110#110\n" \
        "-- Multiple commas are supported:\n" \
        "Test with: org111/repo111#111,, , , and org112/repo112#112\n" \
        "-- Lines with trailing data are accepted, references there are ignored\n" \
        "Test with: org113/repo113#113 android org901/repo901#901\n"\
        "-- A proper separator is required, otherwise it's considered a comment\n" \
        "-- This can become quite odd\n" \
        "Test with: org114/repo114#114org902/repo902#902\n" \
        "Test with: org115/repo115#115 org116/repo116#116org903/repo903#903\n" \
        "Test with: org117/repo117#117andorg904/repo904#904\n" \
        "Test with: org118/repo118#118gliberishorg905/repo905#905\n" \
        "-- Leading space makes the parser ignore things:\n" \
        "  Test with: https://github.com/org906/repo906/pull/906\n" \
        "-- Branch and commit short forms:\n" \
        "Test with: org119/repo119@feature-119\n" \
        "Test with: org120/repo120@foo123\n" \
        "-- Branches with slashes:\n" \
        "Test with: org121/repo121@release/v121\n" \
        "-- Tree and commit URLs:\n" \
        "Test with: https://github.com/org122/repo122/tree/main\n" \
        "Test with: https://github.com/org123/repo123/commit/abc1234567\n" \
        "-- Branch with /:\n" \
        "Test with: https://github.com/org124/repo124/tree/release/v124\n" \
        "-- Mixed list of PRs, branches and commit URLs:\n" \
        "Test with: org125/repo125#125, org126/repo126@dev," \
            " https://github.com/org127/repo127/tree/main\n" \
        "-- Mixed with and:\n" \
        "Test with: org128/repo128#128, org129/repo129@feat," \
            " and org130/repo130@foo\n" \
        "-- Trailing data after a git ref is ignored:\n" \
        "Test with: org131/repo131@feature-131 andromeda org907/repo907@bad\n" \
        "-- Refs with leading dot/dash should not match:\n" \
        "Test with: org908/repo908@.dot\n" \
        "Test with: org909/repo909@-dash\n" \
        "*** TEST END ***"
    )
    print("matches:", a)
    assert a[0]  == "org101/repo101#101"
    assert a[1]  == "org102/repo102#102"
    assert a[2]  == "org103/repo103#103"
    assert a[3]  == "org104/repo104#104"
    assert a[4]  == "org105/repo105#105"
    assert a[5]  == "org106/repo106#106"
    assert a[6]  == "org107/repo107#107"
    assert a[7]  == "org108/repo108#108"
    assert a[8]  == "org109/repo109#109"
    assert a[9]  == "org110/repo110#110"
    assert a[10] == "org111/repo111#111"
    assert a[11] == "org112/repo112#112"
    assert a[12] == "org113/repo113#113"
    assert a[13] == "org114/repo114#114"
    assert a[14] == "org115/repo115#115"
    assert a[15] == "org116/repo116#116"
    assert a[16] == "org117/repo117#117"
    assert a[17] == "org118/repo118#118"
    assert a[18] == "org119/repo119@feature-119"
    assert a[19] == "org120/repo120@foo123"
    assert a[20] == "org121/repo121@release/v121"
    assert a[21] == "org122/repo122@main"
    assert a[22] == "org123/repo123@abc1234567"
    assert a[23] == "org124/repo124@release/v124"
    assert a[24] == "org125/repo125#125"
    assert a[25] == "org126/repo126@dev"
    assert a[26] == "org127/repo127@main"
    assert a[27] == "org128/repo128#128"
    assert a[28] == "org129/repo129@feat"
    assert a[29] == "org130/repo130@foo"
    assert a[30] == "org131/repo131@feature-131"
    assert len(a) == 31

def main():
    if os.environ['GITHUB_EVENT_NAME'] != 'pull_request' and \
       os.environ['GITHUB_EVENT_NAME'] != 'pull_request_target':
        print('Not a pull request')
        sys.exit(1)

    with open(os.environ['GITHUB_EVENT_PATH']) as f:
      event = json.load(f)
    issue_id = int(event['number'])

    # optional auth token
    token = os.environ.get('INPUT_TOKEN')

    # if INPUT_TOKEN is set, but the empty string, use None instead
    if not token:
        token = None

    # get body dynamically so we don't miss updates on test re-run:
    gh = Github(login_or_token=token)
    repo = gh.get_repo(os.environ['GITHUB_REPOSITORY'])
    issue = repo.get_issue(number=issue_id)

    # parse the issue body
    refs = find_refs_to_test_with(issue.body)
    print(" ".join(refs))


if __name__ == '__main__':
    #unit_test()
    main()
